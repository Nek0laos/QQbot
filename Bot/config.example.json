{
  "api_keys": {
    "deepseek": "YOUR_DEEPSEEK_API_KEY",
    "openrouter": "YOUR_OPENROUTER_API_KEY",
    "gemini": "YOUR_GEMINI_API_KEY",
    "groq": "YOUR_GROQ_API_KEY",
    "openai": "YOUR_OPENAI_API_KEY",
    "prodia": "YOUR_PRODIA_API_KEY",
    "hf_token": "",
    "pixiv_refresh_token": ""
  },
  "model_settings": {
    "deepseek_base_url": "https://api.deepseek.com",
    "deepseek_model": "deepseek-v4-flash",
    "deepseek_temperature": 0.75
  },
  "web_search_settings": {
    "enabled": true,
    "max_results": 4,
    "timeout_seconds": 10,
    "auto_for_time_sensitive": true,
    "allow_model_request": true
  },
  "bot_settings": {
    "super_users": [123456789],
    "test_groups": [123456789],
    "host": "127.0.0.1",
    "port": "8080",
    "proxy_url": "http://127.0.0.1:7890"
  },
  "memory_settings": {
    "enabled": true,
    "db_path": "./memory_db",
    "window_size": 30,
    "search_results": 3,
    "max_records_per_group": 5000,
    "embedding_model": "BAAI/bge-small-zh-v1.5",
    "lexical_weight": 0.18,
    "recency_weight": 0.04,
    "context_max_chars": 1500,
    "context_placement": "user_message"
  },
  "pixiv_settings": {
    "min_bookmarks": 100,
    "sample_pool": 80,
    "default_count": 1,
    "max_count": 3,
    "allow_r18": false,
    "allow_ai": false
  }
}
